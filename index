// STORAGE
let tasks=[],notes=[],events={},accounts=[],bills=[];
function load(){
  try{tasks=JSON.parse(localStorage.getItem('o_tasks')); if(!Array.isArray(tasks)) tasks=[];}catch(e){tasks=[];}
  try{notes=JSON.parse(localStorage.getItem('o_notes')); if(!Array.isArray(notes)) notes=[];}catch(e){notes=[];}
  try{events=JSON.parse(localStorage.getItem('o_events'))||{};}catch(e){events={};}
  try{accounts=JSON.parse(localStorage.getItem('o_accs')); if(!Array.isArray(accounts)) accounts=[];}catch(e){accounts=[];}
  
  try {
      let bData = JSON.parse(localStorage.getItem('o_bills')); 
      if(!Array.isArray(bData)) bData=[];
      bills = bData.map(b => {
          if(typeof b.paid === 'boolean') {
              const mk = b.date ? b.date.substring(0,7) : getToday().substring(0,7);
              const pm = {}; if(b.paid) pm[mk] = true;
              return {...b, rep: 0, paidMap: pm, paid: undefined};
          }
          if(b.rep === true) b.rep = -1;
          if(b.rep === false) b.rep = 0;
          if(!b.paidMap) b.paidMap = {};
          return b;
      });
  } catch(e){bills=[];}

  const oldB = parseFloat(localStorage.getItem('o_balance'));
  if(accounts.length===0&&!isNaN(oldB)&&oldB>0){accounts.push({id:Date.now(),name:'Carteira Principal',val:oldB});}
  else if(accounts.length===0) {accounts.push({id:Date.now(),name:'Carteira Principal',val:0});}
}
function save(){
  localStorage.setItem('o_tasks',JSON.stringify(tasks));
  localStorage.setItem('o_notes',JSON.stringify(notes));
  localStorage.setItem('o_events',JSON.stringify(events));
  localStorage.setItem('o_accs', JSON.stringify(accounts));
  localStorage.setItem('o_bills', JSON.stringify(bills));
}


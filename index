// TOUCH DRAG FOR ALL
function bindDrag(containerId, itemClass, onReorder) {
    const g = document.getElementById(containerId);
    if(!g) return;
    let dTimer=null, dEl=null, sx=0, sy=0;

    g.addEventListener('touchstart', e => {
        const t = e.target.closest(itemClass);
        if(!t || e.target.closest('button') || e.target.closest('.bub') || e.target.closest('.h-act') || e.target.closest('.h-opts')) return;
        sx = e.touches[0].clientX; sy = e.touches[0].clientY;
        dTimer = setTimeout(() => {
            dEl = t; dEl.classList.add('dragging');
            dEl.style.opacity = '0.5'; dEl.style.transform = 'scale(0.95)'; dEl.style.transition = 'none';
            if(navigator.vibrate) navigator.vibrate(50);
        }, 500); 
    }, {passive:true});

    g.addEventListener('touchmove', e => {
        if(!dEl && dTimer) { if(Math.abs(e.touches[0].clientX - sx)>15 || Math.abs(e.touches[0].clientY - sy)>15) { clearTimeout(dTimer); dTimer=null; } }
        if(dEl) {
            e.preventDefault();
            const y = e.touches[0].clientY;
            const els = [...g.querySelectorAll(`${itemClass}:not(.dragging)`)];
            const afterEl = els.find(el => y <= el.getBoundingClientRect().top + el.getBoundingClientRect().height / 2);
            if(afterEl) { if(dEl.nextSibling !== afterEl) g.insertBefore(dEl, afterEl); } 
            else { if(g.lastChild !== dEl) g.appendChild(dEl); }
        }
    }, {passive:false});

    const endDrag = () => {
        if(dTimer) { clearTimeout(dTimer); dTimer=null; }
        if(dEl) {
            dEl.classList.remove('dragging');
            dEl.style.opacity = ''; dEl.style.transform = ''; dEl.style.transition = '';
            dEl = null; onReorder();
        }
    };
    g.addEventListener('touchend', endDrag); g.addEventListener('touchcancel', endDrag);
}

// CALENDAR BLINDADO & RECORRÊNCIA
let cY=TY,cM=TM,selD=null,calView='month',wkOff=0;

function isBillInDay(b, dk) {
    if(!b.date) return false;
    if(!b.rep) return b.date === dk; 
    const bY = parseInt(b.date.substring(0,4)), bM = parseInt(b.date.substring(5,7))-1, bD = b.date.substring(8,10);
    const kY = parseInt(dk.substring(0,4)), kM = parseInt(dk.substring(5,7))-1, kD = dk.substring(8,10);
    if(bD !== kD) return false;
    if(kY === bY && kM === bM) return true;
    if(!b.rep || b.rep === 0) return false;
    const diff = (kY - bY) * 12 + (kM - bM);
    if(diff > 0) {
        if(b.rep === -1) return true;
        if(diff <= b.rep) return true;
    }
    return false;
}

function isBillInMonth(b, mk) {
    if(!b.date) return false;
    const bMk = b.date.substring(0,7);
    if(bMk === mk) return true;
    if(!b.rep || b.rep === 0) return false;
    if(mk > bMk) {
        if(b.rep === -1) return true;
        const y1 = parseInt(bMk.substring(0,4)), m1 = parseInt(bMk.substring(5,7));
        const y2 = parseInt(mk.substring(0,4)), m2 = parseInt(mk.substring(5,7));
        const diff = (y2 - y1) * 12 + (m2 - m1);
        if(diff <= b.rep) return true;
    }
    return false;
}

function checkDot(k) {
    let dot = false;
    try {
        let rawE = (events || {})[k];
        if (Array.isArray(rawE) && rawE.length > 0) dot = true;
        if (!dot && Array.isArray(tasks) && tasks.some(t => t && t.dk === k)) dot = true;
        if (!dot && Array.isArray(bills) && bills.some(b => b && isBillInDay(b, k))) dot = true;
    } catch(e) {}
    return dot;
}


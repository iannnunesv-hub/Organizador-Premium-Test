function openTransfer(){
    if(accounts.length < 2) { showDialog('alert','Transferência','Você precisa de pelo menos 2 carteiras.'); return; }
    let opts = accounts.map(a=>`<option value="${a.id}">${a.name} (${fmtC(a.val)})</option>`).join('');
    document.getElementById('tr-from').innerHTML = opts;
    document.getElementById('tr-to').innerHTML = opts;
    document.getElementById('tr-val').value = '';
    openM('mo-transfer');
}
function saveTransfer(){
    const f = parseInt(document.getElementById('tr-from').value);
    const t = parseInt(document.getElementById('tr-to').value);
    const vStr = document.getElementById('tr-val').value;
    const v = parseFloat(vStr.replace(',','.'));
    
    if(f === t) { toast('Selecione carteiras diferentes!'); return; }
    if(!v || v<=0) { toast('Valor inválido!'); return; }

    const accF = accounts.find(a=>a.id===f);
    const accT = accounts.find(a=>a.id===t);
    if(accF && accT) {
        accF.val -= v;
        accT.val += v;
        save(); renderFin(); closeM('mo-transfer'); toast('Transferência realizada ✓');
    }
}


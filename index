    const wc = document.getElementById('pk-wheels');

    if(type === 'date') {
        let [y, m, d] = (val || getToday()).split('-').map(Number);
        let wD = createWheel(1, 31, d, v=>String(v).padStart(2,'0'));
        let wM = createWheel(1, 12, m, v=>MO[v-1].substring(0,3));
        let wY = createWheel(TY-5, TY+10, y, v=>v);

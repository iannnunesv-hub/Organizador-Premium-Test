    try {
        load(); loadCfg(); loadHabits();
        applyTheme(); applyName(); applyHideVals();
        if(typeof chgBillType === 'function') chgBillType(); 
        
        // Define aba ativa silenciosamente
        document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));
        document.querySelectorAll('.tb').forEach(b=>b.classList.remove('active'));
        document.getElementById('sec-agenda').classList.add('active');
        document.getElementById('tb-agenda').classList.add('active');
        
        calView = 'month'; cY = TY; cM = TM; selD = null;

        try{ renderTasks(); } catch(e){}
        try{ renderNotes(); } catch(e){}
        try{ renderHabits(); } catch(e){}
        try{ if(typeof renderFin==='function') renderFin(); } catch(e){}
        
        // Renderiza o calendário, focando no dia de hoje automaticamente
        try{ selDay(TD); } catch(e){}

        try {
            bindDrag('ngrid', '.nc', () => { const arr=[]; document.querySelectorAll('#ngrid .nc').forEach(el=>arr.push(notes.find(n=>n.id===Number(el.dataset.id)))); notes=arr.filter(Boolean); save(); });
            bindDrag('hab-list', '.hcard', () => { const arr=[]; document.querySelectorAll('#hab-list .hcard').forEach(el=>arr.push(habits.find(h=>h.id===Number(el.dataset.id)))); habits=arr.filter(Boolean); saveHabits(); });
        } catch(e) {}
        
        document.getElementById('task-in').addEventListener('keydown', e => { if(e.key==='Enter') addTask(); });
        document.getElementById('ev-in').addEventListener('keydown', e => { if(e.key==='Enter') addEvent(); });
        
        try {
            const p=new URLSearchParams(location.search),txt=(p.get('text')||p.get('url')||'').trim();
            if(txt){notes.unshift({id:Date.now(),title:p.get('title')||'Compartilhado',body:txt,date:NOW.toLocaleDateString('pt-BR')});save();history.replaceState(null,'',location.pathname);window._shared=true;}
        } catch(e) {}
        
        if(window._shared){swTab('notes',document.getElementById('tb-notes'));toast('✓ Texto salvo nas notas!');}
        
        document.addEventListener('visibilitychange', () => { if(!document.hidden) schedAll(); });
        
        // Remove Splash 
        setTimeout(() => {
            const sp = document.getElementById('splash');
            if(sp) sp.remove(); 
            startTutorial();
        }, 2200);

        schedAll();
    } catch (err) { console.error("Erro na inicialização:", err); }
}

initApp();

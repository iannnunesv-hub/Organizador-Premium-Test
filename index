function renderMonth(){
  try {
      const hols = ensureHols(cY) || {};
      const fd = new Date(cY, cM, 1).getDay();
      const dim = new Date(cY, cM + 1, 0).getDate();
      let h = '';
      for(let i=0; i<fd; i++) h += '<div class="cc emp"></div>';
      
      for(let d=1; d<=dim; d++){
          const past = (cY < TY) || (cY === TY && cM < TM) || (cY === TY && cM === TM && d < TD);
          const isT = (d === TD && cM === TM && cY === TY);
          const isSel = (d === selD);
          const k = ck(cY, cM, d);
          const hasDot = checkDot(k);
          const hol = hols[k] || null;
          
          let cls = 'cc';
          if(past) cls += ' past';
          if(isT) cls += ' today';
          if(isSel) cls += ' sel';
          if(hasDot) cls += ' dot';
          if(hol) cls += ' hol';

          h += `<div class="${cls}" onclick="selDay(${d})" title="${esc(hol||'')}">${d}</div>`;
      }
      
      document.getElementById('cal-main').innerHTML = `<div class="cnr"><button class="cnv no-swipe" onclick="chMonth(-1)">‹</button><span>${MO[cM]} ${cY}</span><button class="cnv no-swipe" onclick="chMonth(1)">›</button></div><div class="cdow">${DL.map(d=>`<span>${d[0]}</span>`).join('')}</div><div class="cgrid">${h}</div>`;

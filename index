function expandMonth(k, name) {
  const b = (bills||[]).filter(Boolean).filter(x => isBillInMonth(x, k));
  
  let totalIn = 0, totalOut = 0;
  const catsIn = {}, catsOut = {};
  
  b.forEach(x => {
      const key = x.cat || 'Outro';
      const val = Number(x.val||0);
      if(x.type === '+') {
          totalIn += val;
          if(!catsIn[key]) catsIn[key] = {total:0, items:[]};
          catsIn[key].total += val;
          catsIn[key].items.push(x);
      } else {
          totalOut += val;
          if(!catsOut[key]) catsOut[key] = {total:0, items:[]};
          catsOut[key].total += val;
          catsOut[key].items.push(x);
      }
  });

  const total = totalIn + totalOut;
  const pctIn = total > 0 ? (totalIn / total) * 100 : 50;
  const pctOut = total > 0 ? (totalOut / total) * 100 : 50;
  
  let html = `
    <div style="margin-bottom:15px; background:var(--bg3); padding:14px; border-radius:12px;">
        <div style="display:flex; justify-content:space-between; margin-bottom: 12px;">
            <div style="text-align:center; flex:1; border-right:.5px solid var(--brd2);">
                <div style="font-size:10px; color:var(--txt3); font-weight:600; text-transform:uppercase;">Entradas</div>
                <div class="v-hide" style="font-size:16px; font-weight:600; color:#2e7d32; margin-top:4px;">+${fmtC(totalIn)}</div>
            </div>
            <div style="text-align:center; flex:1;">
                <div style="font-size:10px; color:var(--txt3); font-weight:600; text-transform:uppercase;">Saídas</div>
                <div class="v-hide" style="font-size:16px; font-weight:600; color:#e44; margin-top:4px;">-${fmtC(totalOut)}</div>
            </div>
        </div>
        <div style="display:flex; height:6px; border-radius:3px; overflow:hidden; background:var(--brd2);">
            <div style="width:${pctIn}%; background:#2e7d32; transition:width 0.3s;"></div>
            <div style="width:${pctOut}%; background:#e44; transition:width 0.3s;"></div>
        </div>
    </div>`;

  if(!b.length) {
      html += `<p class="empty" style="margin-top:0">Nenhum lançamento previsto.</p>`;
  } else {
      const renderGrp = (grp, title, color) => {
          const keys = Object.keys(grp).sort();
          if(!keys.length) return '';
          let res = `<div style="font-size:11px; font-weight:600; color:var(--txt3); margin:18px 0 8px; text-transform:uppercase; letter-spacing:0.05em;">${title}</div>`;
          keys.forEach((c) => {
              const cc = grp[c];
              res += `
              <div style="background:var(--card); border:.5px solid var(--brd); border-radius:10px; margin-bottom:8px; overflow:hidden;">
                 <div onclick="const n=this.nextElementSibling; const a=this.querySelector('.arr'); if(n.style.display==='none'){n.style.display='block';a.style.transform='rotate(90deg)';}else{n.style.display='none';a.style.transform='rotate(0deg)';}" style="display:flex; justify-content:space-between; align-items:center; padding:12px; cursor:pointer; font-weight:500; font-size:13px; color:var(--txt); background:var(--bg3);">
                     <div style="display:flex; align-items:center; gap:8px;">
                         <span class="arr" style="display:inline-block; transition:transform 0.2s; color:var(--txt3); font-size:16px; line-height:1;">›</span>
                         <span>${c}</span>
                     </div>
                     <span class="v-hide" style="color:${color}; font-weight:600">${fmtC(cc.total)}</span>
                 </div>
                 <div style="display:none; padding:4px 12px 12px 12px;">`;
              cc.items.forEach(it => {
                  const dText = it.desc || c;
                  const isPaid = it.paidMap && it.paidMap[k];
                  res += `
                    <div style="display:flex; justify-content:space-between; font-size:12px; color:var(--txt2); padding:8px 0; border-bottom:.5px dashed var(--brd2);">
                      <span style="flex:1; padding-right:10px; ${isPaid ? 'text-decoration:line-through;color:var(--txt4)' : ''}">${esc(dText)} ${it.rep?' 🔁':''}</span>
                      <span class="v-hide" style="${isPaid ? 'color:var(--txt4)' : ''}">${fmtC(it.val)}</span>
                    </div>`;
              });
              res = res.replace(/border-bottom:\.5px dashed var\(--brd2\);(">.*?<\/div>)$/, '">$1');
              res += `</div></div>`;
          });
          return res;
      };

      html += renderGrp(catsIn, 'Receitas Detalhadas', '#2e7d32');
      html += renderGrp(catsOut, 'Despesas Detalhadas', '#e44');
  }
  
  document.getElementById('proj-m-ttl').textContent = `Resumo: ${name}`;

// CUSTOM DATE/TIME PICKER
let pkTarget = null;
let pkType = ''; 

function createWheel(min, max, selVal, formatFn) {
    const w = document.createElement('div');
    w.className = 'wheel';
    let html = '<div class="w-pad"></div>';
    let selIdx = 0;
    let idx = 0;
    for(let i=min; i<=max; i++) {
        if(i == selVal) selIdx = idx;
        html += `<div class="w-item" data-val="${i}" data-idx="${idx}" onclick="this.parentElement.scrollTo({top: (${idx} * 50), behavior: 'smooth'})">${formatFn(i)}</div>`;
        idx++;
    }
    html += '<div class="w-pad"></div>';
    w.innerHTML = html;
    
    w.addEventListener('scroll', () => {
        clearTimeout(w.scrollTO);
        w.scrollTO = setTimeout(() => {
            const items = w.querySelectorAll('.w-item');
            let closestIdx = Math.round(w.scrollTop / 50);
            if(closestIdx < 0) closestIdx = 0;
            if(closestIdx >= items.length) closestIdx = items.length - 1;
            
            items.forEach((it, i) => {
                if(i === closestIdx) {
                    it.classList.add('act');
                    w.dataset.val = it.dataset.val;
                } else {
                    it.classList.remove('act');
                }
            });
            
            if (pkType === 'date') {
                const wheels = document.getElementById('pk-wheels').querySelectorAll('.wheel');
                if(wheels.length === 3 && (w === wheels[1] || w === wheels[2])) {
                    const curM = parseInt(wheels[1].dataset.val);
                    const curY = parseInt(wheels[2].dataset.val);
                    const maxD = new Date(curY, curM, 0).getDate();
                    const curD = parseInt(wheels[0].dataset.val);
                    
                    const dayItems = wheels[0].querySelectorAll('.w-item');
                    dayItems.forEach(di => {
                        if(parseInt(di.dataset.val) > maxD) di.style.display = 'none';
                        else di.style.display = 'flex';
                    });
                    if(curD > maxD) {
                        wheels[0].scrollTo({top: (maxD - 1) * 50, behavior: 'smooth'});
                    }
                }
            }
        }, 50);
    });

    setTimeout(() => {
        w.scrollTop = selIdx * 50;
        const items = w.querySelectorAll('.w-item');
        items.forEach((it, i) => {
            if(i === selIdx) { it.classList.add('act'); w.dataset.val = it.dataset.val; }
            else it.classList.remove('act');
        });
    }, 10);
    
    return w;
}

function openPicker(id, type) {
    pkTarget = id; pkType = type;
    const el = document.getElementById(id);
    const val = el.value || '';
    document.getElementById('pk-ttl').textContent = type === 'date' ? 'Selecionar Data' : 'Selecionar Horário';
    

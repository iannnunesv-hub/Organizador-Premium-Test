// Eventos Touch aprimorados
let tsX=0, tsY=0, isSwipe=false, isScroll=false, tsNoSwipe=false, tsOnCal=false;
document.addEventListener('DOMContentLoaded', () => {
    const cnt = document.getElementById('cnt');
    const slider = document.getElementById('slider');
    
    cnt.addEventListener('touchstart', e => {
        tsX = e.touches[0].clientX; tsY = e.touches[0].clientY;
        isSwipe = false; isScroll = false;
        
        tsNoSwipe = !!e.target.closest('.mo') || !!e.target.closest('#fin-proj');
        tsOnCal = !!e.target.closest('#cal-main') && curTab === 0;
        
        if(!tsNoSwipe && !tsOnCal) slider.style.transition = 'none';
    }, {passive:true});

    cnt.addEventListener('touchmove', e => {
        if(tsNoSwipe || tsOnCal || isScroll || document.querySelector('.dragging')) return;
        const dx = e.touches[0].clientX - tsX;
        const dy = e.touches[0].clientY - tsY;
        
        if(!isSwipe && !isScroll) {
            if(Math.abs(dx) > 10 && Math.abs(dx) > Math.abs(dy)) isSwipe = true;
            else if(Math.abs(dy) > 10) isScroll = true;
        }
        
        if(isSwipe) {
            let px = -(curTab * cnt.offsetWidth) + dx;
            if(px > 0) px = px / 3;
            if(px < -(TABS.length-1)*cnt.offsetWidth) px = -(TABS.length-1)*cnt.offsetWidth + (dx/3);
            slider.style.transform = `translateX(${px}px)`;
        }
    }, {passive:true});

    cnt.addEventListener('touchend', e => {
        if(tsOnCal) {
            const dx = e.changedTouches[0].clientX - tsX;
            const dy = e.changedTouches[0].clientY - tsY;
            if(Math.abs(dx) > 50 && Math.abs(dx) > Math.abs(dy)) chMonth(dx < 0 ? 1 : -1);
            return;
        }
        if(tsNoSwipe || document.querySelector('.dragging')) return;
        if(isSwipe) {
            const dx = e.changedTouches[0].clientX - tsX;
            if(dx < -60 && curTab < TABS.length-1) curTab++;
            else if(dx > 60 && curTab > 0) curTab--;
            swTab(TABS[curTab]);
        }
    }, {passive:true});
    
    document.addEventListener('click', e => {
        if(!e.target.closest('.h-menu-btn')) {
            document.querySelectorAll('.h-opts').forEach(el => el.classList.remove('open'));
        }
    });
});


// HABITS
let habits=[],hfd={id:null,icon:'⭐',name:'',color:'#54A0FF',target:1,times:[],frequency:'daily',customDays:[],reminderTime:''},focusH=null,focTmr=null;
function loadHabits(){try{habits=JSON.parse(localStorage.getItem('o_habits2')); if(!Array.isArray(habits)) habits=[];}catch(e){habits=[];}}
function saveHabits(){localStorage.setItem('o_habits2',JSON.stringify(habits));}
function isSchedOn(h,date){const w=date.getDay();if(h.frequency==='daily')return true;if(h.frequency==='weekdays')return w>=1&&w<=5;if(h.frequency==='custom')return(h.customDays||[]).includes(w);return true;}
function getHabCnt(h){return(h.history||{})[getToday()]||0;}
function isHabDone(h){return getHabCnt(h)>=h.target;}
function compStreak(h){const hist=h.history||{};let s=0,d=new Date();d.setHours(0,0,0,0);if(!isHabDone(h))d.setDate(d.getDate()-1);for(let i=0;i<366;i++){if(!isSchedOn(h,d)){d.setDate(d.getDate()-1);continue;}const k=getDK(d);if((hist[k]||0)>=h.target){s++;d.setDate(d.getDate()-1);}else break;}return s;}
function getBadge(s){return s>=100?'💎':s>=30?'🥇':s>=14?'🥈':s>=7?'🥉':'';}

function getHabDots(h) {
    let html = '';
    for(let i=6; i>=0; i--) {
        const d = new Date(); d.setDate(d.getDate() - i);
        const k = getDK(d);
        const cnt = (h.history||{})[k] || 0;
        const isD = cnt >= h.target;
        
        let style = '';
        if(isD) {
            style = `background:${h.color}; opacity: ${i===0?1:0.5};`;
        } else {
            if(i===0) style = `border:1.5px solid ${h.color}; background:transparent; width:4px; height:4px;`;
            else style = `background:var(--brd2); opacity:0.6;`;
        }
        html += `<div class="h-dot" style="${style}"></div>`;
    }
    return html;
}

function incHabit(id) {
    const h = habits.find(x=>x.id===id); if(!h) return;
    const today = getToday();
    if(!h.history) h.history = {};
    let cnt = h.history[today] || 0;
    
    if(cnt < h.target) {
        h.history[today] = cnt + 1;
        saveHabits(); renderHabits();
        if(h.history[today] >= h.target) {
            toast(`🎉 "${h.name}" concluído!`);
            if(navigator.vibrate) navigator.vibrate(50);
        }
    } else {
        if(h.target === 1) { h.history[today] = 0; saveHabits(); renderHabits(); }
        else toast('Hábito já concluído! (Use o menu ⋮ para desfazer)');
    }
    if(focusH && focusH.id === id) { focusH = habits.find(x=>x.id===id); renderFocusBody(); }
}

function undoHabit(id) {
    const h = habits.find(x=>x.id===id); if(!h) return;
    const today = getToday();
    let cnt = (h.history||{})[today] || 0;
    if(cnt > 0) {
        h.history[today] = cnt - 1;
        saveHabits(); renderHabits();
        if(focusH && focusH.id === id) { focusH = habits.find(x=>x.id===id); renderFocusBody(); }
    }
}

function togHabOpt(id) {
    document.querySelectorAll('.h-opts').forEach(el => {
        if(el.id !== `h-opt-${id}`) el.classList.remove('open');
    });
    const el = document.getElementById(`h-opt-${id}`);
    if(el) el.classList.toggle('open');
}

function habCardHTML(h){
    const cnt = getHabCnt(h);
    const str = compStreak(h);
    const bdg = getBadge(str);
    const done = cnt >= h.target;
    const sched = isSchedOn(h, new Date());
    
    const r = 21; const circ = 2 * Math.PI * r;
    const pct = Math.min(cnt / h.target, 1);
    const offset = circ - (pct * circ);
    
    let actIn = '';
    if(done) {
        actIn = `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
    } else if (h.target === 1) {
        actIn = `<div class="h-act-v" style="color:var(--txt3)"></div>`; 
    } else {
        actIn = `<div class="h-act-plus">+</div><div class="h-act-v">${cnt}/${h.target}</div>`;
    }

    return `
    <div class="hcard no-swipe ${done?'done':''} ${!sched?'huns':''}" data-id="${h.id}" onclick="openFocus(${h.id})">
        <div class="h-ico-wrap" style="background:${h.color}22; color:${h.color};">
            ${h.icon}
        </div>
        <div class="h-info">
            <div class="h-nm">${esc(h.name)}</div>
            <div class="h-meta">
                ${str > 0 ? `<span style="color:#e67e22; font-weight:600;">🔥 ${str}</span>` : ''}
                ${bdg ? `<span style="font-size:13px">${bdg}</span>` : ''}
                <div class="h-dots">${getHabDots(h)}</div>
            </div>
        </div>
        <div class="h-act no-swipe" onclick="event.stopPropagation(); incHabit(${h.id})">
            <svg class="h-ring">
                <circle class="h-ring-bg" cx="24" cy="24" r="${r}"></circle>
                <circle class="h-ring-fg" cx="24" cy="24" r="${r}" stroke="${done ? '#1DD1A1' : h.color}" stroke-dasharray="${circ}" stroke-dashoffset="${offset}"></circle>
            </svg>
            <div class="h-act-in" style="${done ? 'background:#1DD1A1; border-radius:50%; width:36px; height:36px;' : ''}">
                ${actIn}
            </div>
        </div>
        <button class="h-menu-btn no-swipe" onclick="event.stopPropagation(); togHabOpt(${h.id})">⋮</button>
        <div class="h-opts no-swipe" id="h-opt-${h.id}">
            <button class="h-opt-btn" onclick="event.stopPropagation(); openHF(${h.id}); togHabOpt(${h.id})">✏ Editar</button>
            ${cnt > 0 ? `<button class="h-opt-btn" onclick="event.stopPropagation(); undoHabit(${h.id}); togHabOpt(${h.id})">↩ Desfazer</button>` : ''}
            <button class="h-opt-btn del" onclick="event.stopPropagation(); delHabit(${h.id}); togHabOpt(${h.id})">🗑 Excluir</button>
        </div>
    </div>`;
}

function renderHabits(){
  try {
      let tod=(habits||[]).filter(Boolean).filter(h=>isSchedOn(h,new Date()));
      let unsched=(habits||[]).filter(Boolean).filter(h=>!isSchedOn(h,new Date()));
      
      // Organiza para os concluídos irem automaticamente para o fim da lista
      tod.sort((a, b) => {
          const doneA = isHabDone(a);
          const doneB = isHabDone(b);
          if(doneA && !doneB) return 1;
          if(!doneA && doneB) return -1;
          return 0;
      });

      const dn=tod.filter(h=>isHabDone(h)), pct=tod.length?Math.round(dn.length/tod.length*100):0;
      const g=pct===100?'#1DD1A1,#48DBFB':'#54A0FF,#A29BFE';
      
      document.getElementById('hab-list').innerHTML=`
        <div class="hprog">
            <div class="hph"><span>${dn.length}/${tod.length} hoje</span><span style="font-size:12px;color:var(--txt3)">${pct}%</span></div>
            <div class="pbw"><div class="pbf" style="width:${pct}%;background:linear-gradient(90deg,${g})"></div></div>
            ${pct===100&&tod.length?'<div class="pbm">🎉 Todos concluídos hoje!</div>':''}
        </div>
        ${tod.length ? tod.map(habCardHTML).join('') : '<p class="empty" style="margin-bottom:15px;">Nenhum hábito para hoje.</p>'}
        ${unsched.length ? `<div class="lbl" style="margin-top:15px; margin-bottom:10px;">Não programados para hoje</div>` + unsched.map(habCardHTML).join('') : ''}
      `;
  } catch(e){}
}


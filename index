<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,user-scalable=no,viewport-fit=cover"/>
<meta name="theme-color" content="#fff"/>
<meta name="mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<link rel="manifest" href="./manifest.json"/>
<title>Organizador Premium</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#fafafa;--bg2:#fff;--bg3:#f5f5f5;--bg4:#e8e8e8;--brd:#eee;--brd2:#ddd;--txt:#222;--txt2:#666;--txt3:#aaa;--txt4:#ccc;--ac:#222;--acfg:#fff;--card:#fff;--inp:#fff;--hol:#e05;}
[data-theme=dark]{--bg:#111;--bg2:#1a1a1a;--bg3:#252525;--bg4:#0d0d0d;--brd:#2a2a2a;--brd2:#383838;--txt:#eee;--txt2:#aaa;--txt3:#666;--txt4:#444;--ac:#e0e0e0;--acfg:#111;--card:#1e1e1e;--inp:#2a2a2a;--hol:#ff6b8a;}

/* PRIVACIDADE: Ocultar valores */
body.hide-vals .v-hide { filter: blur(6px); opacity: 0.6; user-select: none; pointer-events: none; transition: filter 0.2s, opacity 0.2s; }
.v-hide { transition: filter 0.2s, opacity 0.2s; }

/* LAYOUT NATIVO BLINDADO: Impede que a tela inteira role (Scroll do Body) */
body { font-family: system-ui, sans-serif; background: var(--bg4); display: flex; justify-content: center; align-items: center; height: 100vh; height: 100dvh; overflow: hidden; padding: 0.5rem; transition: background .2s; }
#app { width: 100%; height: 100%; max-width: 490px; background: var(--bg); border-radius: 18px; border: .5px solid var(--brd); overflow: hidden; display: flex; flex-direction: column; position: relative; box-shadow: 0 4px 20px rgba(0,0,0,0.05); }

/* SPLASH SCREEN PREMIUM */
#splash { position: absolute; inset: 0; background: var(--bg); z-index: 9999; display: flex; align-items: center; justify-content: center; flex-direction: column; border-radius: 18px; animation: fadeOutSplash 0.6s ease-in-out forwards; animation-delay: 1.4s; pointer-events: none; }
.sp-ico { font-size: 54px; margin-bottom: 12px; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1)); }
.sp-title { font-size: 24px; font-weight: 300; color: var(--txt); letter-spacing: 1px; }
.sp-prem { font-weight: 700; color: #d4af37; font-style: italic; letter-spacing: 0; }
@keyframes fadeOutSplash { 0% { opacity: 1; visibility: visible; } 100% { opacity: 0; visibility: hidden; z-index: -1; display: none; } }

.hdr{background:var(--bg2);border-bottom:.5px solid var(--brd);padding:14px 17px 11px;display:flex;justify-content:space-between;align-items:center;flex-shrink:0}
.hdr h1{font-size:18px;font-weight:500;color:var(--txt)}
.hdr p{font-size:11px;color:var(--txt2);margin-top:4px;font-style:italic;line-height:1.4}
.hdr-r{display:flex;gap:7px;align-items:center}
.ibt{background:none;border:.5px solid var(--brd2);border-radius:9px;padding:6px 8px;cursor:pointer;font-size:16px;line-height:1;display:flex;align-items:center}
.gear-btn{background:none;border:.5px solid var(--brd2);border-radius:9px;padding:7px;cursor:pointer;display:flex;align-items:center;color:var(--txt2)}

/* NATIVE SLIDER CSS & SCROLL DA ABA INTEIRA */
.cnt{flex:1; overflow:hidden; position:relative; min-height:0;} 
#slider { display:flex; width:500%; height:100%; transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1); will-change: transform; }
.sec{width:20%; flex-shrink:0; padding:1.2rem 1.1rem; display:flex; flex-direction:column; overflow-y:auto; overflow-x:hidden; height:100%; box-sizing:border-box;}
.sec > * { flex-shrink: 0; } 

.tabbar{display:flex;border-top:.5px solid var(--brd);background:var(--bg2);flex-shrink:0; padding-bottom: env(safe-area-inset-bottom);}
.tb{flex:1;padding:11px 2px 9px;border:none;background:none;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:3px;color:var(--txt4);font-size:11px;font-family:inherit;transition:color .15s}
.tb.active{color:var(--txt);font-weight:500}
.tb svg{width:18px;height:18px}
input,textarea,select{padding:9px 12px;border-radius:9px;border:.5px solid var(--brd2);font-size:14px;outline:none;font-family:inherit;background:var(--inp);color:var(--txt); width: 100%; box-sizing: border-box;}
.pk-input { cursor: pointer; caret-color: transparent; }
textarea{resize:none;line-height:1.65;width:100%}
.ib{padding:9px 15px;border-radius:9px;border:none;background:var(--ac);color:var(--acfg);font-size:18px;cursor:pointer;flex-shrink:0}
.bd{background:none;border:none;cursor:pointer;color:var(--txt4);font-size:16px;padding:0 4px;flex-shrink:0}
.lbl{font-size:11px;color:var(--txt3);margin-bottom:5px;font-weight:500;letter-spacing:.07em;text-transform:uppercase}
.empty{text-align:center;color:var(--txt4);font-size:14px;margin-top:2rem}
.bbk{background:none;border:.5px solid var(--brd2);border-radius:9px;padding:7px 12px;cursor:pointer;font-size:13px;color:var(--txt2);font-family:inherit}
.bsv{background:var(--ac);color:var(--acfg);border:none;border-radius:9px;padding:7px 14px;font-size:13px;cursor:pointer;font-family:inherit}

/* MODALS */
.mo{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:100;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .2s}
.mo.open{opacity:1;pointer-events:all}
.md{background:var(--bg2);border-radius:20px 20px 0 0;width:100%;max-width:490px;max-height:90vh;display:flex;flex-direction:column;transform:translateY(30px);transition:transform .25s}
.mo.open .md{transform:translateY(0)}
.mh{display:flex;justify-content:space-between;align-items:center;padding:16px 19px 13px;border-bottom:.5px solid var(--brd);flex-shrink:0}
.mh h2{font-size:15px;font-weight:500;color:var(--txt)}
.mc{background:none;border:none;font-size:23px;cursor:pointer;color:var(--txt3);line-height:1}
.mb{overflow-y:auto;flex:1;padding:14px 19px}
.mf{padding:12px 19px 20px;flex-shrink:0;border-top:.5px solid var(--brd)}

/* CUSTOM DIALOG */
#mo-dialog { z-index: 150; align-items: center; padding: 1rem; }
.md-center { margin: auto; transform: translateY(20px) scale(0.95); max-width: 320px; border-radius: 18px; padding-top: 15px; background: var(--bg2); width: 100%; display: flex; flex-direction: column; transition: all .2s; }
#mo-dialog.open .md-center { transform: translateY(0) scale(1); }
.dia-btns { display: flex; border-top: .5px solid var(--brd); margin-top: 20px; }
.dia-btn { flex: 1; padding: 14px; background: none; border: none; font-size: 15px; cursor: pointer; font-family: inherit; }
.dia-btn.cancel { border-right: .5px solid var(--brd); color: var(--txt3); }
.dia-btn.ok { color: var(--ac); font-weight: 600; }

/* ROLLING WHEEL PICKER */
#mo-picker { z-index: 140; }
.pk-wheels { display: flex; justify-content: center; gap: 15px; height: 210px; position: relative; width: 100%; overflow: hidden; margin-top: 10px; }
.pk-sel-bg { position: absolute; top: 80px; left: 0; right: 0; height: 50px; background: rgba(0,0,0,0.05); border-radius: 12px; z-index: 0; pointer-events: none; }
[data-theme=dark] .pk-sel-bg { background: rgba(255,255,255,0.08); }
.wheel { flex: 1; overflow-y: auto; scroll-snap-type: y mandatory; scrollbar-width: none; position: relative; z-index: 1; height: 100%; scroll-behavior: auto; overscroll-behavior-y: contain; }
.wheel::-webkit-scrollbar { display: none; }
.w-pad { height: 80px; } 
.w-item { height: 50px; display: flex; align-items: center; justify-content: center; font-size: 22px; font-weight: 500; color: var(--txt3); scroll-snap-align: center; transition: all 0.15s ease-out; cursor: pointer; user-select: none; }
.w-item.act { font-size: 28px; font-weight: 700; color: var(--ac); }

/* SETTINGS */
.cst{font-size:11px;color:var(--txt3);font-weight:500;letter-spacing:.08em;text-transform:uppercase;margin:15px 0 9px}
.cst:first-child{margin-top:0}
.cr{display:flex;justify-content:space-between;align-items:center;padding:11px 0;border-bottom:.5px solid var(--brd)}
.cr:last-child{border-bottom:none}
.cl{font-size:14px;color:var(--txt)}
.tog{position:relative;width:44px;height:24px;flex-shrink:0}
.tog input{opacity:0;width:0;height:0;position:absolute}
.tog-s{position:absolute;inset:0;background:var(--brd2);border-radius:24px;cursor:pointer;transition:background .2s}
.tog-s::before{content:'';position:absolute;width:18px;height:18px;left:3px;top:3px;background:#fff;border-radius:50%;transition:transform .2s}
.tog input:checked+.tog-s{background:#555}
.tog input:checked+.tog-s::before{transform:translateX(20px)}
.ns{font-size:12px;font-weight:500}.ns.on{color:#3a3}.ns.off{color:var(--txt3)}
.bncfg{background:var(--ac);color:var(--acfg);border:none;border-radius:8px;padding:6px 12px;font-size:12px;cursor:pointer;font-family:inherit}

/* TASKS & BILLS */
.tf{background:var(--card);border-radius:13px;border:.5px solid var(--brd);padding:13px;margin-bottom:1rem;flex-shrink:0}
.tftop{display:flex;gap:7px;margin-bottom:10px}
.tftop input{flex:1}
.tf2{display:flex;gap:8px;flex-wrap:wrap; align-items:flex-start;}
.tff{display:flex;flex-direction:column;gap:4px;flex:1;min-width:85px;}
.tff label{font-size:10px;color:var(--txt3);font-weight:600;letter-spacing:.04em;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tff input,.tff select{font-size:13px;padding:7px;height:34px;}

.ti{display:flex;align-items:flex-start;gap:9px;padding:11px 13px;border-radius:10px;border:.5px solid var(--brd);margin-bottom:6px;background:var(--card)}
.ti.done-item .tt{text-decoration:line-through;color:var(--txt4)}
.tck{width:19px;height:19px;border-radius:50%;border:1.5px solid var(--txt4);cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;margin-top:2px;transition:all .15s}
.tck.done{background:var(--ac);border-color:var(--ac)}
.tb2{flex:1;min-width:0}
.tt{font-size:14px;color:var(--txt);line-height:1.4}
.tm{font-size:11px;color:var(--txt3);margin-top:2px}
.tm.ov{color:#e44}
.dtb{display:flex;gap:1px;flex-shrink:0}
.brev{background:none;border:none;cursor:pointer;font-size:14px;padding:3px 5px;color:var(--txt3)}
.bperm{background:none;border:none;cursor:pointer;font-size:14px;padding:3px 5px;color:#e44}
.dtoggle{width:100%;padding:10px 13px;border-radius:10px;border:.5px solid var(--brd);background:var(--card);text-align:left;color:var(--txt3);font-size:13px;cursor:pointer;font-family:inherit;display:flex;align-items:center;gap:7px;margin-top:.8rem;flex-shrink:0}
.dtoggle .arr{margin-left:auto;transition:transform .2s;font-size:14px}
.dtoggle.open .arr{transform:rotate(90deg)}

/* NOTES, LISTS & CARDS SELECTION LOCK */
.nc, .hcard { -webkit-user-select: none; user-select: none; -webkit-touch-callout: none; }
.ng{display:flex;flex-direction:column;gap:9px; padding-bottom:10px;}
.nc{border-radius:11px;border:.5px solid var(--brd);padding:14px;cursor:pointer;background:var(--card);transition:transform 0.2s, opacity 0.2s, box-shadow 0.2s;}
.nc.dragging, .hcard.dragging { z-index: 10; position: relative; }
.nc h3{font-size:14px;font-weight:500;color:var(--txt);margin-bottom:4px}
.nc p{font-size:12px;color:var(--txt3);margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.nf{display:flex;justify-content:space-between;align-items:center}
.nd{font-size:10px;color:var(--txt4)}
.bnn{width:100%;padding:11px;border-radius:10px;border:.5px dashed var(--brd2);background:transparent;font-size:14px;color:var(--txt3);cursor:pointer;margin-bottom:1rem;font-family:inherit;flex-shrink:0}
#nlv{flex:1;display:flex;flex-direction:column;min-height:0}
.neh{display:flex;justify-content:space-between;align-items:center;margin-bottom:.7rem;flex-shrink:0}
#nt-ttl{border:none;outline:none;font-size:18px;font-weight:500;color:var(--txt);padding:0;margin-bottom:.6rem;border-radius:0;width:100%;background:transparent;flex-shrink:0}
#nt-bdy{border:none;outline:none;font-size:14px;color:var(--txt2);padding:0;border-radius:0;background:transparent;flex:1;min-height:0;height:calc(100svh - 230px)}
#nev{flex:1;display:none;flex-direction:column;overflow:hidden}
#nev.open{display:flex}

.nli { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
.nli input[type=text] { flex: 1; padding: 8px 10px; font-size: 13px; }
.nli-chk { width: 22px; height: 22px; border-radius: 6px; border: 1.5px solid var(--txt4); display: flex; align-items: center; justify-content: center; cursor: pointer; color: transparent; flex-shrink:0; transition:all 0.15s;}
.nli-chk.done { background: var(--ac); border-color: var(--ac); color: var(--acfg); }
.nli.done input { text-decoration: line-through; color: var(--txt4); }

/* CALENDAR */
.vrow{display:flex;gap:6px;margin-bottom:.8rem;flex-shrink:0}
.vbtn{flex:1;padding:7px;border-radius:8px;border:.5px solid var(--brd2);background:var(--bg3);color:var(--txt2);font-size:12px;cursor:pointer;font-family:inherit}
.vbtn.sel{background:var(--ac);color:var(--acfg);border-color:var(--ac)}
.srow{display:flex;gap:7px;margin-bottom:.8rem;flex-shrink:0}
.srow input{flex:1;font-size:13px}
.sri{padding:9px 11px;border-radius:9px;border:.5px solid var(--brd);margin-bottom:5px;background:var(--card);cursor:pointer}
.sri-t{font-size:13px;color:var(--txt)}
.sri-m{font-size:11px;color:var(--txt3);margin-top:2px}
.cnr{display:flex;align-items:center;justify-content:space-between;margin-bottom:.8rem}
.cnr span{font-size:14px;font-weight:500;color:var(--txt)}
.cnv{background:none;border:none;font-size:18px;cursor:pointer;color:var(--txt3);padding:4px 8px}
.cdow{display:grid;grid-template-columns:repeat(7,1fr);gap:1px;margin-bottom:3px}
.cdow span{text-align:center;font-size:10px;color:var(--txt4);font-weight:500}
.cgrid{display:grid;grid-template-columns:repeat(7,1fr);gap:2px}
.cc{height:36px;display:flex;flex-direction:column;align-items:center;justify-content:center;border-radius:7px;cursor:pointer;position:relative;font-size:13px;color:var(--txt)}
.cc:hover{background:var(--bg3)}.cc.past{color:var(--txt4)}.cc.today{background:var(--bg3);font-weight:600}
.cc.sel{background:var(--ac)!important;color:var(--acfg)!important}
.cc.dot::after{content:'';width:3px;height:3px;border-radius:50%;background:currentColor;position:absolute;bottom:3px;opacity:.5}
.cc.sel.dot::after{background:var(--acfg);opacity:.8}
.cc.emp{cursor:default}.cc.emp:hover{background:transparent}
.cc.hol{color:var(--hol)}.cc.sel.hol{color:var(--acfg)}
.evs{margin-top:.8rem;border-top:.5px solid var(--brd);padding-top:.8rem;flex-shrink:0}
.edl{font-size:12px;color:var(--txt3);margin-bottom:8px}
.holbanner{background:rgba(200,0,50,.07);border:.5px solid rgba(200,0,50,.18);border-radius:8px;padding:6px 10px;margin-bottom:8px;font-size:12px;color:var(--hol);display:flex;align-items:center;gap:5px}

/* CALENDAR SLIDE ANIMATIONS */
@keyframes slideCalNext { 0% { transform: translateX(30px); opacity: 0; } 100% { transform: translateX(0); opacity: 1; } }
@keyframes slideCalPrev { 0% { transform: translateX(-30px); opacity: 0; } 100% { transform: translateX(0); opacity: 1; } }
.cal-next { animation: slideCalNext 0.25s ease-out; }
.cal-prev { animation: slideCalPrev 0.25s ease-out; }

.ef{display:flex;flex-direction:column;gap:6px;margin-bottom:.8rem}
.efr{display:flex;gap:6px;align-items:flex-end}
.efl{display:flex;flex-direction:column;gap:3px;flex:1}
.efl label{font-size:10px;color:var(--txt3);font-weight:600;letter-spacing:.06em;text-transform:uppercase}
.efr input,.efr select{font-size:12px;padding:7px 8px}
.efr button{padding:8px 11px;border-radius:8px;border:none;background:var(--ac);color:var(--acfg);font-size:12px;cursor:pointer;font-family:inherit;white-space:nowrap;flex-shrink:0}
.evi{display:flex;align-items:center;gap:8px;padding:9px 11px;border-radius:9px;border:.5px solid var(--brd);margin-bottom:5px;background:var(--card)}
.evi.done-ev .et2{text-decoration:line-through;color:var(--txt4)}
.ei2{flex:1;min-width:0}
.et2{font-size:13px;color:var(--txt)}
.em2{font-size:11px;color:var(--txt3);margin-top:2px}
.ebdg{display:inline-block;font-size:10px;background:var(--bg3);color:var(--txt3);border-radius:3px;padding:1px 5px;margin-left:4px}
.etask{background:#fff3e0;color:#b07}.eev{background:#e8f4ff;color:#46a}

/* WEEK/DAY */
.wstrip{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:.8rem}
.wd{display:flex;flex-direction:column;align-items:center;padding:6px 2px;border-radius:9px;cursor:pointer;position:relative}
.wd:hover{background:var(--bg3)}.wd.sel{background:var(--ac)}
.wd.sel .wdn,.wd.sel .wdd{color:var(--acfg)}.wd.today .wdd{font-weight:700}
.wdn{font-size:10px;color:var(--txt4);margin-bottom:2px;font-weight:500}.wdd{font-size:14px;color:var(--txt)}
.wd.past .wdd{color:var(--txt4)}
.wd.dot::after{content:'';width:3px;height:3px;border-radius:50%;background:var(--ac);position:absolute;bottom:3px;opacity:.6}
.wd.sel.dot::after{background:var(--acfg)}.wd.hol .wdd{color:var(--hol)}
.dtl{display:flex;flex-direction:column;gap:5px}
.dti{display:flex;gap:9px;align-items:center;padding:9px 11px;border-radius:9px;border:.5px solid var(--brd);background:var(--card)}
.dtt{font-size:11px;color:var(--txt3);min-width:36px;flex-shrink:0}
.dtb2{flex:1;min-width:0}
.dttl{font-size:13px;color:var(--txt)}.dttl.done{text-decoration:line-through;color:var(--txt4)}

/* --- HABITOS: NOVO VISUAL --- */
.hprog{background:var(--card);border-radius:13px;border:.5px solid var(--brd);padding:13px 14px;margin-bottom:.9rem;flex-shrink:0}
.hph{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px}
.hph span{font-size:13px;color:var(--txt2);font-weight:500}
.pbw{background:var(--bg3);border-radius:99px;height:7px;overflow:hidden}
.pbf{height:100%;border-radius:99px;transition:width .5s cubic-bezier(.4,0,.2,1)}
.pbm{font-size:12px;color:var(--txt3);margin-top:6px;text-align:center}

.hcard{display:flex;align-items:center;padding:14px;gap:14px;border-radius:18px;background:var(--card);border:.5px solid var(--brd);margin-bottom:12px;transition:all .3s ease;position:relative;flex-shrink:0;}
.hcard.done{opacity:0.55;background:var(--bg3);}
.hcard.huns{opacity:0.4; filter: grayscale(0.8);}
.h-ico-wrap{width:48px;height:48px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;flex-shrink:0;}
.h-info{flex:1;min-width:0;display:flex;flex-direction:column;gap:5px;}
.h-nm{font-size:15px;font-weight:600;color:var(--txt);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.h-meta{display:flex;align-items:center;gap:8px;font-size:11px;color:var(--txt3);}
.h-dots{display:flex;gap:3px;}
.h-dot{width:6px;height:6px;border-radius:50%;background:var(--brd2);}
.h-act{width:48px;height:48px;flex-shrink:0;position:relative;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform .1s;}
.h-act:active{transform:scale(.9);}
.h-ring{transform:rotate(-90deg);width:48px;height:48px;overflow:visible;}
.h-ring circle{fill:transparent;stroke-width:4;stroke-linecap:round;}
.h-ring-bg{stroke:var(--brd2);}
.h-ring-fg{transition:stroke-dashoffset 0.4s cubic-bezier(0.4, 0, 0.2, 1), stroke 0.3s;}
.h-act-in{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;flex-direction:column;transition:all 0.3s;}
.h-act-v{font-size:13px;font-weight:600;color:var(--txt);line-height:1;}
.h-act-plus{font-size:14px;line-height:1;color:var(--txt3);margin-bottom:1px;font-weight:500;}
.h-menu-btn{background:none;border:none;font-size:20px;color:var(--txt4);padding:4px;cursor:pointer;line-height:1;margin-left:-4px;}
.h-opts{position:absolute;right:16px;top:40px;background:var(--card);border:.5px solid var(--brd);border-radius:12px;padding:6px;display:flex;flex-direction:column;gap:2px;box-shadow:0 6px 16px rgba(0,0,0,0.1);z-index:10;opacity:0;pointer-events:none;transform:translateY(-10px);transition:all 0.2s;}
.h-opts.open{opacity:1;pointer-events:all;transform:translateY(0);}
.h-opt-btn{background:transparent;border:none;padding:10px 14px;border-radius:8px;font-size:13px;font-weight:500;color:var(--txt2);cursor:pointer;text-align:left;white-space:nowrap;font-family:inherit;}
.h-opt-btn:hover{background:var(--bg3);color:var(--txt);}
.h-opt-btn.del{color:#e44;}
.h-opt-btn.del:hover{background:#ffebee;color:#c62828;}

/* HABIT FORM */
.hff{margin-bottom:13px}
.hff label{display:block;font-size:11px;color:var(--txt3);font-weight:500;letter-spacing:.07em;text-transform:uppercase;margin-bottom:5px}
.hff input[type=text],.hff input[type=time],.hff select{width:100%}
.ecat-lbl{font-size:10px;color:var(--txt4);margin-bottom:4px;margin-top:8px;font-weight:600;letter-spacing:.04em}
.ecat-lbl:first-child{margin-top:0}
.emoji-row{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:2px}
.eopt{font-size:22px;cursor:pointer;padding:4px 5px;border-radius:7px;border:1.5px solid transparent;line-height:1;transition:transform .1s}
.eopt:hover{background:var(--bg3)}
.eopt.sel{border-color:var(--ac);background:var(--bg3);transform:scale(1.1)}
.csw-row{display:flex;gap:7px;flex-wrap:wrap}
.csw{width:29px;height:29px;border-radius:50%;cursor:pointer;border:3px solid transparent;transition:transform .1s}
.csw.sel{border-color:var(--txt);transform:scale(1.12)}
.frow{display:flex;gap:6px;flex-wrap:wrap}
.fbtn{padding:6px 12px;border-radius:99px;border:.5px solid var(--brd2);font-size:13px;cursor:pointer;background:var(--bg3);color:var(--txt2);font-family:inherit}
.fbtn.sel{background:var(--ac);color:var(--acfg);border-color:var(--ac)}
.drow{display:flex;gap:5px;margin-top:8px}
.dck{width:33px;height:33px;border-radius:50%;border:.5px solid var(--brd2);font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;background:var(--bg3);color:var(--txt2);font-family:inherit;flex-shrink:0}
.dck.sel{background:var(--ac);color:var(--acfg)}
.tst{display:flex;align-items:center;gap:11px}
.tsb{width:32px;height:32px;border-radius:50%;border:.5px solid var(--brd2);background:var(--bg3);color:var(--txt);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:inherit;flex-shrink:0}
.tsv{font-size:18px;font-weight:500;color:var(--txt);min-width:18px;text-align:center}
.tsl{font-size:12px;color:var(--txt3)}
.htgrid{display:flex;flex-direction:column;gap:6px;margin-top:5px}
.htrow{display:flex;align-items:center;gap:9px;padding:6px 10px;background:var(--bg3);border-radius:8px}
.htrow span{font-size:12px;color:var(--txt2);flex-shrink:0;min-width:80px}
.htrow input{flex:1}

/* FOCUS */
.fbubs{display:flex;gap:9px;justify-content:center;flex-wrap:wrap;margin:12px 0 5px}
.fbub{width:40px;height:40px;border-radius:50%;border:2.5px solid currentColor;cursor:pointer;transition:background .15s}
.fbub:active{transform:scale(.88)}.fbub.filled{background:currentColor}
.fcnt{text-align:center;font-size:13px;color:var(--txt3);margin-bottom:12px}
.fsts{display:flex;justify-content:center;gap:22px;margin-bottom:10px}
.fs{text-align:center}
.fsn{font-size:22px;font-weight:500;color:var(--txt)}.fsl{font-size:11px;color:var(--txt3);margin-top:1px}
.fq{text-align:center;font-size:13px;color:var(--txt3);font-style:italic;padding:0 8px;margin:10px 0}
.hgs{margin:10px 0}
.hdow{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;margin-bottom:3px}
.hdow span{text-align:center;font-size:10px;color:var(--txt4)}
.hgrid{display:grid;grid-template-columns:repeat(7,1fr);gap:3px}
.hcl{aspect-ratio:1;border-radius:4px;background:var(--bg3)}.hcl.done{opacity:.85}.hcl.today{box-shadow:0 0 0 1.5px var(--txt)}
.tmrsec{margin-top:12px;padding-top:12px;border-top:.5px solid var(--brd);text-align:center}
.topts{display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:8px}
.topt{padding:6px 11px;border-radius:99px;border:.5px solid var(--brd2);font-size:12px;cursor:pointer;background:var(--bg3);color:var(--txt2);font-family:inherit}
.topt.sel{background:var(--ac);color:var(--acfg)}
.tcrow{display:flex;align-items:center;gap:8px;justify-content:center;margin-bottom:8px}
.tcrow input{width:68px;text-align:center;font-size:14px;padding:6px 8px}
.tdisp{font-size:44px;font-weight:200;color:var(--txt);letter-spacing:.04em;margin:4px 0 9px;font-variant-numeric:tabular-nums}
.tbtn{padding:10px 28px;border-radius:99px;border:none;background:var(--ac);color:var(--acfg);font-size:14px;cursor:pointer;font-family:inherit}

/* ACHIEVEMENTS */
.ach-stat{font-size:12px;color:var(--txt3);margin-bottom:12px;line-height:1.8}
.ach-stat strong{color:var(--txt)}
.ach-sec{margin-bottom:16px}
.ach-sec-ttl{font-size:12px;color:var(--txt3);font-weight:600;letter-spacing:.07em;text-transform:uppercase;margin-bottom:9px}
.ach-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:9px}
.ach-card{display:flex;flex-direction:column;align-items:center;padding:13px 8px;border-radius:12px;border:.5px solid var(--brd);background:var(--card);text-align:center}
.ach-card.locked{opacity:.32;filter:grayscale(1)}
.ach-ico{font-size:28px;margin-bottom:5px;line-height:1}
.ach-ttl{font-size:11px;font-weight:500;color:var(--txt);line-height:1.3;margin-bottom:2px}
.ach-dsc{font-size:10px;color:var(--txt3);line-height:1.3}

/* SUGGESTIONS */
.sug-grid{display:flex;flex-direction:column;gap:7px}
.sug-item{display:flex;align-items:center;gap:10px;padding:11px 13px;border-radius:10px;border:.5px solid var(--brd);background:var(--card)}
.sug-ico{font-size:22px;flex-shrink:0}
.sug-info{flex:1;min-width:0}
.sug-nm{font-size:13px;font-weight:500;color:var(--txt)}
.sug-dt{font-size:11px;color:var(--txt3);margin-top:1px}
.sug-add{background:var(--ac);color:var(--acfg);border:none;border-radius:7px;padding:6px 12px;font-size:12px;cursor:pointer;font-family:inherit;flex-shrink:0}

/* TUTORIAL */
#tut{position:fixed;inset:0;z-index:200;display:flex;align-items:flex-end;justify-content:center;padding:0 1rem 1rem}
#tut-bg{position:absolute;inset:0;background:rgba(0,0,0,.55)}
.tut-card{position:relative;background:var(--bg2);border-radius:18px;padding:22px;width:100%;max-width:460px;z-index:1}
.tut-ico{font-size:38px;text-align:center;margin-bottom:9px}
.tut-ttl{font-size:17px;font-weight:600;color:var(--txt);text-align:center;margin-bottom:7px}
.tut-txt{font-size:13px;color:var(--txt2);text-align:center;line-height:1.65;margin-bottom:16px}
.tut-dots{display:flex;justify-content:center;gap:5px;margin-bottom:14px}
.tut-dot{width:6px;height:6px;border-radius:50%;background:var(--brd2);transition:all .2s}
.tut-dot.active{background:var(--ac);width:20px;border-radius:3px}
.tut-row{display:flex;gap:9px}
.tut-skip{flex:1;padding:11px;border-radius:10px;border:.5px solid var(--brd2);background:transparent;color:var(--txt3);cursor:pointer;font-family:inherit;font-size:13px}
.tut-next{flex:2;padding:11px;border-radius:10px;border:none;background:var(--ac);color:var(--acfg);cursor:pointer;font-family:inherit;font-size:13px;font-weight:500}

/* FINANCES */
.f-card{background:var(--card);border-radius:13px;border:.5px solid var(--brd);padding:13px;margin-bottom:1rem;flex-shrink:0}
.f-bal{display:flex;justify-content:space-between;align-items:flex-start}
.f-v{font-size:26px;font-weight:600;color:var(--txt);margin-top:2px}
.acc-list{margin-top:10px;display:flex;flex-direction:column;gap:5px}
.acc-it{display:flex;justify-content:space-between;align-items:center;padding:8px 10px;background:var(--bg3);border-radius:8px;font-size:13px;color:var(--txt)}
.acc-nm{font-weight:500;display:flex;align-items:center;gap:5px}
.acc-val{color:var(--txt2)}
.cat-it{display:flex;justify-content:space-between;padding:6px 0;border-bottom:.5px solid var(--brd2);font-size:13px;color:var(--txt)}
.cat-it:last-child{border-bottom:none}
</style>
</head>
<body>

<div id="splash">
    <div class="sp-ico">👑</div>
    <div class="sp-title">Organizador <span class="sp-prem">Premium</span></div>
</div>

<div id="app">
  <div class="hdr">
    <div><h1 id="aname">Meu Organizador</h1><p id="dlbl"></p></div>
    <div class="hdr-r">
      <button class="ibt" onclick="openAch()" title="Conquistas">🏆</button>
      <button class="gear-btn" onclick="openCfg()" title="Configurações">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
        </svg>
      </button>
    </div>
  </div>
  
  <div class="cnt" id="cnt">
    <div id="slider">
        <div id="sec-agenda" class="sec active">
          <div class="vrow">
            <button class="vbtn sel" id="vbtn-month" onclick="setView('month')">Mês</button>
            <button class="vbtn" id="vbtn-week" onclick="setView('week')">Semana</button>
            <button class="vbtn" id="vbtn-day" onclick="setView('day')">Dia</button>
          </div>
          <div class="srow"><input type="text" id="cal-srch" placeholder="🔍 Buscar tarefas e eventos..." oninput="renderSearch()"/></div>
          <div id="srch-res" style="display:none"></div>
          <div id="cal-main" style="flex-shrink:0" class="no-swipe"></div>
          <div id="ev-sec" class="evs" style="display:none">
            <p class="edl" id="ev-dlbl"></p>
            <div id="hol-row" style="display:none" class="holbanner">🎉 <span id="hol-nm"></span></div>
            <div class="ef">
              <input type="text" id="ev-in" placeholder="Nome do evento..."/>
              <div class="efr">
                <div class="efl"><label>Hora</label><input type="text" id="ev-time" class="pk-input" readonly onclick="openPicker(this.id, 'time')" placeholder="--:--"/></div>
                <div class="efl"><label>Notificar</label>
                  <select id="ev-ntf">
                    <option value="0">Sem aviso</option><option value="5">5 min</option>
                    <option value="10" selected>10 min</option><option value="15">15 min</option>
                    <option value="30">30 min</option><option value="60">1h</option><option value="120">2h</option>
                  </select>
                </div>
                <button onclick="addEvent()" style="margin-bottom:1px">+ Evento</button>
              </div>
            </div>
            <div id="ev-list" style="padding-bottom:20px;"></div>
          </div>
        </div>
        
        <div id="sec-tasks" class="sec">
          <div class="tf">
            <div class="tftop"><input type="text" id="task-in" placeholder="Nova tarefa..."/><button class="ib" onclick="addTask()">+</button></div>
            <div class="tf2">
              <div class="tff"><label>Dia</label><input type="text" id="task-date" class="pk-input" readonly onclick="openPicker(this.id, 'date')" placeholder="Sem data"/></div>
              <div class="tff"><label>Hora</label><input type="text" id="task-time" class="pk-input" readonly onclick="openPicker(this.id, 'time')" placeholder="--:--"/></div>
              <div class="tff"><label>Repetir</label>
                <select id="task-rep">
                  <option value="0">Não</option><option value="1">Diário</option>
                  <option value="7">Semanal</option><option value="30">Mensal</option>
                </select>
              </div>
              <div class="tff"><label>Notificar</label>
                <select id="task-ntf">
                  <option value="0">Sem aviso</option><option value="5">5 min</option>
                  <option value="10" selected>10 min</option><option value="60">1 hora</option>
                </select>
              </div>
            </div>
          </div>
          <div id="t-pend" style="padding-bottom:10px;"></div>
          <div id="t-done-wrap"></div>
        </div>

        <div id="sec-notes" class="sec">
          <div id="nlv">
            <div style="display:flex; gap:8px; margin-bottom:1rem; flex-shrink:0;">
                <button class="bnn" style="margin:0;flex:1;" onclick="openNote('new','text')">+ Texto</button>
                <button class="bnn" style="margin:0;flex:1;" onclick="openNote('new','list')">+ Lista</button>
            </div>
            <div id="ngrid" class="ng"></div>
          </div>
          <div id="nev">
            <div class="neh"><button class="bbk" onclick="closeNote(true)">← Voltar</button><button class="bsv" onclick="saveNote()">Salvar</button></div>
            <input type="text" id="nt-ttl" placeholder="Título"/>
            <textarea id="nt-bdy" placeholder="Escreva sua nota..."></textarea>
            <div id="nt-list-wrap" style="display:none; flex:1; flex-direction:column; overflow-y:auto; padding-bottom:20px;">
               <div id="nt-list-items"></div>
               <button class="bnn" style="border-style:dashed; margin-top:8px;" onclick="addListItem()">+ Adicionar item</button>
            </div>
          </div>
        </div>

        <div id="sec-habitos" class="sec">
          <div style="display:flex;gap:8px;margin-bottom:1rem">
            <button class="bnn" style="margin-bottom:0;flex:1" onclick="openHF(null)">+ Novo Hábito</button>
            <button class="bnn" style="margin-bottom:0;flex:1;border-style:solid;background:var(--bg2)" onclick="openSug()">💡 Sugestões</button>
          </div>
          <div id="hab-list" style="padding-bottom:15px"></div>
        </div>

        <div id="sec-fin" class="sec">
          <div class="f-card">
             <div class="f-bal">
                <div style="flex:1; padding-right:12px; min-width:0;">
                  <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                    <div class="lbl" style="margin-bottom:0">Saldo Total (Soma)</div>
                    <button class="bd no-swipe" id="btn-hide-vals" onclick="toggleHideVals()" style="padding:0; margin-bottom:2px; color:var(--txt3);" title="Ocultar valores">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                    </button>
                  </div>
                  <div class="f-v v-hide" id="fin-total">R$ 0,00</div>
                </div>
                <div style="display:flex; gap:6px; flex-shrink:0;">
                  <button class="ib" style="font-size:13px; padding:6px 12px; background:var(--bg3); color:var(--txt2); border:.5px solid var(--brd2)" onclick="openTransfer()">⇄ Transf.</button>
                  <button class="ib" style="font-size:13px; padding:6px 12px; background:var(--bg3); color:var(--txt2); border:.5px solid var(--brd2)" onclick="addAccount()">+ Cart.</button>
                </div>
             </div>
             <div id="acc-list" class="acc-list"></div>
          </div>
          <div style="margin-bottom:1rem">
             <div class="lbl" style="margin-bottom:8px">Projeção Mês a Mês</div>
             <div id="fin-proj" class="no-swipe" style="overscroll-behavior-x: contain; touch-action: pan-x pan-y; overflow-x:auto; display:flex; gap:8px; padding-bottom:8px; scroll-behavior:smooth"></div>
          </div>
          
          <div class="cnr" style="margin:1.2rem 0 .5rem">
            <button class="cnv" onclick="chgFinM(-1)">‹</button>
            <span id="fin-mlbl" style="font-size:13px;font-weight:600"></span>
            <button class="cnv" onclick="chgFinM(1)">›</button>
          </div>

          <div class="tf">
            <div class="tftop" style="gap:8px; margin-bottom:8px; align-items:center;">
               <select id="bill-type" onchange="chgBillType()" style="width:35%; flex-shrink:0; padding:9px; font-size:14px; border-radius:9px; border:.5px solid var(--brd2); background:var(--inp);">
                   <option value="-">🔴 Saída</option>
                   <option value="+">🟢 Entrada</option>
               </select>
               <select id="bill-cat" style="width:65%; flex-shrink:1; padding:9px; font-size:14px; border-radius:9px; border:.5px solid var(--brd2); background:var(--inp);"></select>
            </div>
            <div class="tftop">
               <input type="text" id="bill-desc" placeholder="Descrição (Opcional)" style="flex:1"/>
               <button class="ib" onclick="addBill()">+</button>
            </div>
            <div class="tf2">
              <div class="tff"><label id="lbl-bill-date">Vencimento</label><input type="text" id="bill-date" class="pk-input" readonly onclick="openPicker(this.id, 'date')" placeholder="Dia..."/></div>
              <div class="tff"><label>Valor (R$)</label><input type="number" id="bill-val" step="0.01" placeholder="0.00" min="0"/></div>
              <div class="tff" style="flex-basis: 100%; flex-direction:row; align-items:center; gap:8px; margin-top:4px">
                 <label style="margin:0; text-transform:none; font-size:12px; font-weight:500; color:var(--txt);">🔁 Repetir:</label>
                 <select id="bill-rep" onchange="chgRep(this)" style="flex:1; font-size:13px; padding:6px 8px; height:32px; min-width:0;">
                     <option value="0">Não repetir</option>
                     <option value="-1">Fixo (Todo mês)</option>
                     <option value="1">Por mais 1 mês</option>
                     <option value="2">Por mais 2 meses</option>
                     <option value="3">Por mais 3 meses</option>
                     <option value="6">Por mais 6 meses</option>
                     <option value="10">Por mais 10 meses</option>
                     <option value="12">Por mais 12 meses (1 ano)</option>
                     <option value="custom">Personalizado...</option>
                 </select>
              </div>
            </div>
          </div>
          <div id="bill-list" style="padding-bottom:20px;"></div>
        </div>
    </div>
  </div>

  <div class="tabbar">
    <button id="tb-agenda" class="tb active" onclick="swTab('agenda',this)"><svg viewBox="0 0 18 18" fill="none"><rect x="2" y="4" width="14" height="12" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M6 2v3M12 2v3M2 8h14" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>Agenda</button>
    <button id="tb-tasks" class="tb" onclick="swTab('tasks',this)"><svg viewBox="0 0 18 18" fill="none"><rect x="2" y="2" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.3"/><path d="M6 9l2 2 4-4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>Tarefas</button>
    <button id="tb-notes" class="tb" onclick="swTab('notes',this)"><svg viewBox="0 0 18 18" fill="none"><rect x="3" y="2" width="12" height="14" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M6 6h6M6 9h6M6 12h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>Notas</button>
    <button id="tb-habitos" class="tb" onclick="swTab('habitos',this)"><svg viewBox="0 0 18 18" fill="none"><path d="M9 3a6 6 0 1 1 0 12A6 6 0 0 1 9 3zm0 2v4l2.5 2.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>Hábitos</button>
    <button id="tb-fin" class="tb" onclick="swTab('fin',this)"><svg viewBox="0 0 24 24" fill="none"><rect x="3" y="6" width="18" height="12" rx="2" stroke="currentColor" stroke-width="1.6"/><path d="M16 12h.01M3 10h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>Finanças</button>
  </div>
</div>

<div id="tut" style="display:none">
  <div id="tut-bg"></div>
  <div class="tut-card">
    <div class="tut-ico" id="tut-ico"></div>
    <div class="tut-ttl" id="tut-ttl"></div>
    <div class="tut-txt" id="tut-txt"></div>
    <div class="tut-dots" id="tut-dots"></div>
    <div class="tut-row"><button class="tut-skip" onclick="endTutorial()">Pular</button><button class="tut-next" id="tut-next" onclick="nextTut()">Próximo →</button></div>
  </div>
</div>

<div class="mo" id="mo-dialog" onclick="bgC(event,'mo-dialog')">
  <div class="md-center">
     <div style="padding:20px 20px 10px; text-align:center;">
        <h3 id="dia-ttl" style="font-size:17px; margin-bottom:8px; color:var(--txt);"></h3>
        <p id="dia-txt" style="font-size:14px; color:var(--txt2); line-height:1.4;"></p>
        <input type="text" id="dia-inp" style="width:100%; margin-top:15px; display:none; text-align:center; padding:10px; border-radius:10px; border:1px solid var(--brd2); font-size:15px;" />
     </div>
     <div class="dia-btns">
        <button id="dia-btn-cancel" class="dia-btn cancel" onclick="closeDialog(false)">Cancelar</button>
        <button id="dia-btn-ok" class="dia-btn ok" onclick="closeDialog(true)">OK</button>
     </div>
  </div>
</div>

<div class="mo" id="mo-picker" onclick="bgC(event,'mo-picker')"><div class="md">
  <div class="mh"><h2 id="pk-ttl">Selecionar</h2><button class="mc" onclick="closeM('mo-picker')">×</button></div>

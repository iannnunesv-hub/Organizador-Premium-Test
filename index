async function chgRep(el) {
    if(el.value === 'custom') {
        const v = await showDialog('prompt', 'Repetição', 'Repetir por quantos meses a mais? (Ex: 24)');
        const num = parseInt(v);
        if(!isNaN(num) && num > 0) {
            let exists = false;
            for(let i=0; i<el.options.length; i++) {
                if(el.options[i].value == num) { exists = true; break; }
            }
            if(!exists) {
                const opt = document.createElement('option');
                opt.value = num;
                opt.text = `Por mais ${num} meses`;
                el.add(opt, el.options[el.options.length-1]); 
            }
            el.value = num;
        } else {
            el.value = "0"; 
        }
    }
}

